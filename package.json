    "arktype": "^2.1.19",
    "nanoid": "^5.1.5",
    "partyserver": "^0.0.75",
    "partysocket": "^1.0.3",
    "radix-ui": "^1.1.3",
    "react": "19.0.0",
    "react-day-picker": "^9.5.1",
    "react-dom": "19.0.0",
    "react-scan": "^0.2.9",
    "react-yjs": "^2.0.1",
    "tailwind-merge": "^3.0.2",
    "tailwindcss": "^4.0.10",
